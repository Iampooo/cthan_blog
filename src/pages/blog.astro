---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ArticleList from '../components/ArticleList.astro';
---

<Base title="All Articles">
  <Nav />
  <main class="max-w-[680px] mx-auto px-4 md:px-8 py-12">
    <header class="mb-12">
      <h1 class="text-3xl font-serif font-bold text-text mb-4">Index</h1>
      <p class="text-text-muted">A collection of essays, memos, and learning notes.</p>
    </header>
    
    <ArticleList />
  </main>
</Base>
