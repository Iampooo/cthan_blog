---
<div class="mb-12 font-sans text-sm flex flex-col sm:flex-row sm:items-center gap-4 border-b border-border pb-6 overflow-x-auto">
  <div class="flex items-center gap-2">
    <span class="text-text-muted">Sort by:</span>
    <button class="filter-sort font-medium hover:text-accent data-[active=true]:text-accent underline decoration-transparent data-[active=true]:decoration-current underline-offset-4" data-sort="desc" data-active="true">Latest</button>
    <button class="filter-sort font-medium hover:text-accent data-[active=true]:text-accent underline decoration-transparent data-[active=true]:decoration-current underline-offset-4" data-sort="asc" data-active="false">Oldest</button>
  </div>
  
  <div class="hidden sm:block text-border">|</div>
  
  <div class="flex items-center gap-2 whitespace-nowrap">
    <span class="text-text-muted">Article Type:</span>
    <button class="filter-type font-medium hover:text-accent data-[active=true]:text-accent underline decoration-transparent data-[active=true]:decoration-current underline-offset-4" data-type="all" data-active="true">All</button>
    <button class="filter-type font-medium hover:text-accent data-[active=true]:text-accent underline decoration-transparent data-[active=true]:decoration-current underline-offset-4" data-type="essay" data-active="false">essay</button>
    <button class="filter-type font-medium hover:text-accent data-[active=true]:text-accent underline decoration-transparent data-[active=true]:decoration-current underline-offset-4" data-type="memo" data-active="false">memo</button>
    <button class="filter-type font-medium hover:text-accent data-[active=true]:text-accent underline decoration-transparent data-[active=true]:decoration-current underline-offset-4" data-type="note" data-active="false">note</button>
  </div>
</div>
